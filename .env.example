# =============================================================================
# Financer — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=financer
POSTGRES_USER=financer
POSTGRES_PASSWORD=financer_local

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Service Ports (local dev / serverless-offline)
AUTH_SERVICE_PORT=3001
EXPENSE_SERVICE_PORT=3002
BUDGET_SERVICE_PORT=3003
INCOME_SERVICE_PORT=3004
DASHBOARD_SERVICE_PORT=3005
LLM_SERVICE_PORT=3006

# Frontend (Vite) — service base URLs
# Change these if your services run on different hosts/ports
VITE_AUTH_URL=http://localhost:3001
VITE_EXPENSE_URL=http://localhost:3002
VITE_BUDGET_URL=http://localhost:3003
VITE_INCOME_URL=http://localhost:3004
VITE_DASHBOARD_URL=http://localhost:3005
VITE_LLM_URL=http://localhost:3006

# Ollama (Phase 3 — LLM features)
# Full models (~8 GB peak VRAM):  use bash scripts/setup-all.sh
# Lite models (~4 GB peak VRAM):  use bash scripts/setup-all.sh --lite-llm
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:9b
OLLAMA_OCR_MODEL=glm-ocr
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_EMBED_DIMENSIONS=1024
# For lite setup, change to:
# OLLAMA_CHAT_MODEL=phi4-mini
# OLLAMA_OCR_MODEL=moondream
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_EMBED_DIMENSIONS=768
