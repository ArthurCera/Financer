{
  "name": "financer",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack finance organizer — monorepo root",
  "scripts": {
    "setup": "bash scripts/setup-all.sh",
    "migrate": "bash scripts/migrate.sh",
    "dev": "bash scripts/run/run-all.sh",
    "dev:backend": "bash scripts/run/run-backend.sh",
    "dev:frontend": "bash scripts/run/run-frontend.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "nuke": "bash scripts/nuke.sh",
    "nuke:force": "bash scripts/nuke.sh --force",
    "docker:logs": "docker compose logs -f",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r tsc --noEmit",
    "test:backend": "vitest run --config vitest.config.ts",
    "test:backend:watch": "vitest --config vitest.config.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.10",
      "esbuild": ">=0.25.0"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9",
    "vue-eslint-parser": "^10.4.0"
  }
}
